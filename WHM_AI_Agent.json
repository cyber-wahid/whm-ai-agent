      },
      "id": "c6031c7b-0ec6-445c-b2a2-4f407fa38eca",
      "name": "Is Authorized User?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        -3632,
        480
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $('AI Platform Settings').item.json.LLM_API_ENDPOINT }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{ $('AI Platform Settings').item.json.LLM_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {   \"model\": $('AI Platform Settings').item.json.LLM_MODEL,   \"messages\": [     {       \"role\": \"user\",       \"content\": \"SYSTEM INSTRUCTION: You are an autonomous WHM Administrator Machine. You DO NOT give explanations. You EXECUTE actions. ALWAYS output exactly in JSON format.\\n\\nRule 1: If user says hello or thanks or general talk, output: {\\\"action\\\":\\\"chat\\\",\\\"reply\\\":\\\"Hello, I am ready!\\\"}\\n\\nRule 2: If user asks for ANY server info or action BUT does not explicitly type 'CONFIRM', DO NOT EXPLAIN HOW TO DO IT. You MUST output exactly: {\\\"action\\\":\\\"chat\\\",\\\"reply\\\":\\\"⚠️ Please reply again with your command and add the word CONFIRM to execute it on the server.\\\"} \\n\\nRule 3: If user asks for info or action AND includes the word 'CONFIRM', MUST translate their natural language into the correct WHM/cPanel API endpoint and output exactly: {\\\"action\\\":\\\"whm_api\\\",\\\"url_path\\\":\\\"[API_PATH]\\\"}.\\n\\nCrucial API Guidelines to construct [API_PATH]:\\n1. For Server Admin Tasks (create, suspend, terminate, summary, password reset): Use native WHM API 1. Example: 'suspendacct?api.version=1&user=USERNAME'.\\n2. For ALL User-Level cPanel Tasks (emails, databases, domains, ssl, ftp): You MUST use the WHM UAPI wrapper `uapi_cpanel`. Format: 'uapi_cpanel?api.version=1&cpanel.user=USERNAME&cpanel.module=MODULE_NAME&cpanel.function=FUNCTION_NAME'. ALWAYS use dot-notation for core UAPI parameters!\\n\\n---\\n\\nUSER REQUEST: \" + $json.message.text     }   ] } }}",
        "options": {}
      },
      "id": "dd49aa96-d003-4f2f-8bcb-1db1c624b38e",
      "name": "LLM Engine",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        -3424,
        464
      ]
    },
    {
      "parameters": {
        "jsCode": "const content = $input.first().json.choices[0]?.message?.content || '{}';\n\n// Clean markdown formatting if model hallucinates it\nlet cleaned = content.replace(/```json/g, '').replace(/```/g, '').trim();\n\nlet parsed = {};\ntry {\n  parsed = JSON.parse(cleaned);\n} catch(e) {\n  // Regex fallback: Extract first complete matching JSON bracket structure\n  const match = content.match(/\\{[\\s\\S]*\\}/);\n  if (match) {\n    parsed = JSON.parse(match[0]);\n  } else {\n    parsed = { \"action\": \"chat\", \"reply\": \"Error parsing AI response inside n8n: \" + content };\n  }\n}\n\nreturn parsed;"
      },
      "id": "e3503fab-a45e-4034-a617-4400a15addf1",
      "name": "Parse & Clean JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3232,
        464
      ]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.action }}",
        "rules": {
          "rules": [
            {
              "value2": "chat"
            },
            {
              "value2": "whm_api",
              "output": 1
            }
          ]
        }
      },
