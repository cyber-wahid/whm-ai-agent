        496
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ [YOUR_TELEGRAM_USER_ID, ANOTHER_AUTHORIZED_USER_ID].includes($json.message.from.id) }}",
              "value2": true
            }
          ]
